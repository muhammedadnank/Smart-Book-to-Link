{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/proxy"
    },
    {
      "source": "/f/:path*",
      "destination": "/api/proxy"
    },
    {
      "source": "/status",
      "destination": "/api/proxy"
    },
    {
      "source": "/((?!api|f|status).*)",
      "destination": "/index.html"
    }
  ]
}
